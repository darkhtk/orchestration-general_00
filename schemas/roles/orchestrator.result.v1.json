{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "orch-engine/schemas/roles/orchestrator.result.v1.json",
  "title": "Orchestrator Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "decision",
    "next_state",
    "reason",
    "unresolved_items",
    "recommended_next_action"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "complete_cycle",
        "needs_iteration",
        "blocked"
      ]
    },
    "next_state": {
      "type": "string",
      "enum": [
        "completed",
        "iterating",
        "blocked"
      ]
    },
    "reason": {
      "type": "string"
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_action": {
      "type": "string"
    }
  }
}
